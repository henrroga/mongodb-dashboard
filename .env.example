# ===== Server =====
PORT=3000
NODE_ENV=production

# Public URL where the dashboard will be reachable (used in docs/links).
PUBLIC_URL=https://mongo.example.com

# Trust the X-Forwarded-* headers from your reverse proxy.
# 'loopback' is correct for a local proxy (Caddy/nginx on same host or in compose).
# Use 1 / 2 for the number of proxies in front, or a CIDR like 10.0.0.0/8.
TRUST_PROXY=loopback

# ===== Auth (REQUIRED for any internet-exposed deployment) =====
AUTH_ENABLED=true

# Either set AUTH_PASSWORD (will be hashed in memory at boot — fine for local dev)
# OR pre-hash with `npm run hash-password` and set AUTH_PASSWORD_HASH (recommended for prod).
# AUTH_PASSWORD=change-me
AUTH_PASSWORD_HASH=

# 32+ random bytes. Generate with:  openssl rand -hex 32
SESSION_SECRET=

# Session lifetime in milliseconds. Default 7 days.
SESSION_MAX_AGE_MS=604800000

# Force secure cookies (HTTPS only). Auto-on in production. Set to false for local HTTP.
# COOKIE_SECURE=true

# Brute-force lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MS=900000

# ===== Operating modes =====
# Block all writes (insert/update/delete/drop/index changes) when true.
READ_ONLY=false

# Pre-configure a MongoDB connection string. When set, the dashboard auto-connects
# at boot and the user does not have to enter the URI. Recommended for self-hosting.
# MONGODB_URI=mongodb://user:pass@host:27017/?authSource=admin

# ===== Rate limiting =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_LOGIN_MAX=10
