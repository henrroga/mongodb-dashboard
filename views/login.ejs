<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | MongoDB Dashboard</title>
  <script>
    (function() {
      try {
        const theme = localStorage.getItem('mongodb_dashboard_theme') || 'system';
        document.documentElement.setAttribute('data-theme', theme);
      } catch(e) {
        document.documentElement.setAttribute('data-theme', 'system');
      }
    })();
  </script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="connect-page">
  <div class="connect-container">
    <div class="connect-header">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="connect-icon" aria-hidden="true">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
      </svg>
      <h1>Sign in</h1>
      <p class="connect-subtitle">Sign in with your dashboard username and password</p>
    </div>

    <form method="POST" action="/login" class="connect-form" autocomplete="off">
      <input type="hidden" name="next" value="<%= next %>">
      <div class="form-group">
        <label for="username">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          autocomplete="username"
          autofocus
          required
        >
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          required
        >
      </div>
      <button type="submit" class="btn btn-primary btn-lg">Sign in</button>
      <% if (error) { %>
        <p class="error-message" style="display:block"><%= error %></p>
      <% } %>
    </form>
  </div>
</body>
</html>
