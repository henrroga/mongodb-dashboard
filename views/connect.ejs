<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connect | MongoDB Dashboard</title>
  <script>
    (function() {
      try {
        const theme = localStorage.getItem('mongodb_dashboard_theme') || 'system';
        document.documentElement.setAttribute('data-theme', theme);
      } catch(e) {
        document.documentElement.setAttribute('data-theme', 'system');
      }
    })();
  </script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="connect-page">
  <header class="header" style="position: absolute; top: 0; left: 0; right: 0; background: transparent; border-bottom: none; justify-content: flex-end;">
    <div class="header-actions">
      <div class="theme-toggle">
        <button class="theme-toggle-btn" title="Theme">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="theme-toggle-text">System</span>
        </button>
        <div class="theme-dropdown">
          <div class="theme-option active" data-theme="system">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span>System</span>
          </div>
          <div class="theme-option" data-theme="light">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <span>Light</span>
          </div>
          <div class="theme-option" data-theme="dark">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
            <span>Dark</span>
          </div>
        </div>
      </div>
    </div>
  </header>
  <div class="connect-container">
    <div id="reconnectLoading" class="reconnect-loading" style="display: none;">
      <div class="loading-spinner"></div>
      <p>Reconnecting to your last session...</p>
    </div>
    
    <div id="connectContent">
      <div class="connect-header">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="connect-icon">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        <h1>MongoDB Dashboard</h1>
        <p class="connect-subtitle">Connect to your MongoDB instance</p>
      </div>

      <!-- Connection mode tabs -->
      <div class="conn-tabs">
        <button class="conn-tab active" data-mode="uri">Connection String</button>
        <button class="conn-tab" data-mode="builder">Fill in fields</button>
      </div>

      <form id="connectForm" class="connect-form">
        <!-- URI Mode -->
        <div id="conn-uri-mode">
          <div class="form-group">
            <label for="connectionString">Connection String</label>
            <input 
              type="text" 
              id="connectionString" 
              name="connectionString" 
              placeholder="mongodb://localhost:27017 or mongodb+srv://..."
              autocomplete="off"
              spellcheck="false"
            >
          </div>
        </div>

        <!-- Builder Mode -->
        <div id="conn-builder-mode" style="display:none">
          <div class="conn-builder-grid">
            <div class="form-group" style="grid-column:span 2">
              <label>Scheme</label>
              <div style="display:flex;gap:12px">
                <label class="conn-radio"><input type="radio" name="cbScheme" value="mongodb://" checked> mongodb://</label>
                <label class="conn-radio"><input type="radio" name="cbScheme" value="mongodb+srv://"> mongodb+srv://</label>
              </div>
            </div>
            <div class="form-group" id="cbHostGroup">
              <label>Host</label>
              <input type="text" id="cbHost" class="conn-field" placeholder="localhost" value="localhost"/>
            </div>
            <div class="form-group" id="cbPortGroup">
              <label>Port</label>
              <input type="number" id="cbPort" class="conn-field" placeholder="27017" value="27017" min="1" max="65535"/>
            </div>
            <div class="form-group" style="grid-column:span 2">
              <label>Authentication</label>
              <select id="cbAuthType" class="conn-field">
                <option value="none">None</option>
                <option value="password">Username / Password</option>
              </select>
            </div>
            <div id="cbAuthFields" style="display:none;grid-column:span 2;display:none">
              <div class="conn-builder-grid">
                <div class="form-group">
                  <label>Username</label>
                  <input type="text" id="cbUsername" class="conn-field" placeholder="admin" autocomplete="off"/>
                </div>
                <div class="form-group">
                  <label>Password</label>
                  <input type="password" id="cbPassword" class="conn-field" placeholder="••••••••" autocomplete="off"/>
                </div>
                <div class="form-group" style="grid-column:span 2">
                  <label>Auth Database</label>
                  <input type="text" id="cbAuthDb" class="conn-field" placeholder="admin" value="admin"/>
                </div>
              </div>
            </div>
            <div class="form-group" style="grid-column:span 2">
              <label>Replica Set Name <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
              <input type="text" id="cbReplicaSet" class="conn-field" placeholder="rs0"/>
            </div>
            <div class="form-group" style="grid-column:span 2;display:flex;align-items:center;gap:10px">
              <input type="checkbox" id="cbTLS"/>
              <label for="cbTLS" style="margin:0">TLS / SSL</label>
            </div>
            <div class="form-group" style="grid-column:span 2">
              <label>Generated URI</label>
              <input type="text" id="cbGeneratedUri" class="conn-field mono" readonly style="background:var(--bg-tertiary)"/>
            </div>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg" id="connectBtn">
          <span class="btn-text">Connect</span>
          <span class="btn-loading" style="display: none;">
            <svg class="spinner" width="20" height="20" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="32" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <p id="connectError" class="error-message" style="display: none;"></p>
      </form>

      <div id="recentConnections" class="recent-connections" style="display: none;">
        <h3>Saved Connections</h3>
        <ul id="recentList"></ul>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    initConnectPage();
  </script>
</body>
</html>
