<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | MongoDB Dashboard</title>
    <script>
      (function () {
        try {
          const theme =
            localStorage.getItem("mongodb_dashboard_theme") || "system";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "system");
        }
      })();
    </script>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/fold/foldgutter.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/hint/show-hint.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/javascript/javascript.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/edit/matchbrackets.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/edit/closebrackets.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/fold/foldcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/fold/foldgutter.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/fold/brace-fold.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/hint/show-hint.min.js"></script>
  </head>
  <body>
    <header class="header">
      <a href="/" class="logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
          />
        </svg>
        MongoDB Dashboard
      </a>
      <nav class="nav">
        <a href="/databases" class="nav-link">Databases</a>
        <span class="nav-sep">/</span>
        <a href="/browse/<%= dbName %>" class="nav-link"><%= dbName %></a>
        <% if (activeCollection) { %>
        <span class="nav-sep">/</span>
        <span class="nav-current"><%= activeCollection %></span>
        <% } %>
        <span class="nav-sep">|</span>
        <a href="/performance" class="nav-link">Performance</a>
      </nav>
      <div class="header-actions">
        <div class="theme-toggle">
          <button class="theme-toggle-btn" title="Theme">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              />
            </svg>
            <span class="theme-toggle-text">System</span>
          </button>
          <div class="theme-dropdown">
            <div class="theme-option active" data-theme="system">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                />
              </svg>
              <span>System</span>
            </div>
            <div class="theme-option" data-theme="light">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                />
              </svg>
              <span>Light</span>
            </div>
            <div class="theme-option" data-theme="dark">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                />
              </svg>
              <span>Dark</span>
            </div>
          </div>
        </div>
        <button
          id="disconnectBtn"
          class="btn btn-sm btn-ghost"
          title="Disconnect"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"
            />
          </svg>
        </button>
      </div>
    </header>

    <!-- Open Tabs bar -->
    <div class="open-tabs-bar" id="openTabsBar"></div>

    <main class="main">
      <div class="browser-layout">
        <aside class="sidebar">
          <div class="sidebar-header">
            <h2>Collections</h2>
            <div style="display:flex;align-items:center;gap:6px;">
              <span class="collection-count"><%= collections.length %></span>
              <button id="createCollectionBtn" class="btn btn-sm btn-ghost sidebar-create-btn" title="Create Collection">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </button>
            </div>
          </div>
          <nav class="collection-list" id="collectionList">
            <% collections.forEach(function(col) { %>
            <div class="collection-item-wrapper <%= activeCollection === col.name ? 'active' : '' %>">
              <a
                href="/browse/<%= dbName %>/<%= col.name %>"
                class="collection-item <%= activeCollection === col.name ? 'active' : '' %>"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
                </svg>
                <span class="collection-name"><%= col.name %></span>
                <span class="collection-doc-count" data-count="<%= col.count %>"><%= col.count %></span>
              </a>
              <div class="collection-actions">
                <button class="col-action-btn col-rename-btn" data-col="<%= col.name %>" title="Rename">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                </button>
                <button class="col-action-btn col-drop-btn" data-col="<%= col.name %>" title="Drop">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                  </svg>
                </button>
              </div>
            </div>
            <% }); %>
          </nav>

          <!-- Create Collection Modal -->
          <div id="createColModal" class="modal" style="display:none">
            <div class="modal-backdrop"></div>
            <div class="modal-content modal-sm">
              <div class="modal-header">
                <h3>Create Collection</h3>
                <button class="modal-close" id="createColModalClose">&times;</button>
              </div>
              <div class="modal-body">
                <div class="form-field">
                  <label>Collection Name</label>
                  <input type="text" id="newColName" class="query-input" placeholder="my_collection" autocomplete="off"/>
                </div>
                <p id="createColError" class="error-message" style="display:none;margin-top:10px"></p>
              </div>
              <div class="modal-footer">
                <button id="createColCancel" class="btn btn-ghost">Cancel</button>
                <button id="createColConfirm" class="btn btn-primary">Create</button>
              </div>
            </div>
          </div>

          <!-- Drop Collection Modal -->
          <div id="dropColModal" class="modal" style="display:none">
            <div class="modal-backdrop"></div>
            <div class="modal-content modal-sm">
              <div class="modal-header">
                <h3>Drop Collection</h3>
                <button class="modal-close" id="dropColModalClose">&times;</button>
              </div>
              <div class="modal-body">
                <p>Drop <strong id="dropColName"></strong>? All documents will be permanently deleted.</p>
                <p id="dropColError" class="error-message" style="display:none;margin-top:10px"></p>
              </div>
              <div class="modal-footer">
                <button id="dropColCancel" class="btn btn-ghost">Cancel</button>
                <button id="dropColConfirm" class="btn btn-danger">Drop</button>
              </div>
            </div>
          </div>

          <!-- Rename Collection Modal -->
          <div id="renameColModal" class="modal" style="display:none">
            <div class="modal-backdrop"></div>
            <div class="modal-content modal-sm">
              <div class="modal-header">
                <h3>Rename Collection</h3>
                <button class="modal-close" id="renameColModalClose">&times;</button>
              </div>
              <div class="modal-body">
                <div class="form-field">
                  <label>New Name</label>
                  <input type="text" id="renameColNewName" class="query-input" placeholder="new_name" autocomplete="off"/>
                </div>
                <p id="renameColError" class="error-message" style="display:none;margin-top:10px"></p>
              </div>
              <div class="modal-footer">
                <button id="renameColCancel" class="btn btn-ghost">Cancel</button>
                <button id="renameColConfirm" class="btn btn-primary">Rename</button>
              </div>
            </div>
          </div>
        </aside>

        <div class="content">
          <% if (activeCollection) { %>
          <!-- Tab bar -->
          <div class="collection-tabs">
            <button class="collection-tab active" data-tab="documents">Documents</button>
            <button class="collection-tab" data-tab="indexes">Indexes</button>
            <button class="collection-tab" data-tab="schema">Schema</button>
            <button class="collection-tab" data-tab="aggregation">Aggregation</button>
            <button class="collection-tab" data-tab="validation">Validation</button>
            <button class="collection-tab" data-tab="stats">Stats</button>
            <button class="collection-tab" data-tab="changes">Changes</button>
            <button class="collection-tab" data-tab="sql">SQL &rarr; MQL</button>
          </div>

          <!-- Documents panel -->
          <div id="panel-documents">
          <div class="content-header">
            <div class="content-title">
              <h2><%= activeCollection %></h2>
              <span id="docCount" class="doc-count"></span>
            </div>
            <div class="content-search">
              <div class="search-input-wrapper">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="search-icon"
                >
                  <circle cx="11" cy="11" r="8" />
                  <path d="M21 21l-4.35-4.35" />
                </svg>
                <input
                  type="text"
                  id="searchInput"
                  class="search-input"
                  placeholder="Search all fields..."
                  autocomplete="off"
                />
                <button
                  id="clearSearchBtn"
                  class="search-clear"
                  style="display: none"
                  title="Clear search"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M18 6L6 18M6 6l12 12" />
                  </svg>
                </button>
              </div>
            </div>
            <div class="content-actions">
              <div class="view-mode-toggle" id="viewModeToggle">
                <button class="view-mode-btn active" data-view="table" title="Table View">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/>
                  </svg>
                </button>
                <button class="view-mode-btn" data-view="list" title="List View">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
                    <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                  </svg>
                </button>
                <button class="view-mode-btn" data-view="json" title="JSON View">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                  </svg>
                </button>
              </div>
              <button id="importBtn" class="btn btn-ghost" title="Import Documents">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                  <polyline points="17 8 12 3 7 8"/>
                  <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                Import
              </button>
              <button id="exportBtn" class="btn btn-ghost" title="Export Documents">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Export
              </button>
              <button
                id="columnsBtn"
                class="btn btn-ghost"
                title="Select Columns"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M3 3h18v18H3zM3 9h18M9 3v18" />
                </svg>
                Columns
              </button>
              <button id="refreshBtn" class="btn btn-ghost" title="Refresh">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M23 4v6h-6M1 20v-6h6" />
                  <path
                    d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"
                  />
                </svg>
              </button>
              <button id="addDocBtn" class="btn btn-primary">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 5v14M5 12h14" />
                </svg>
                Add Document
              </button>
            </div>
          </div>

          <!-- Query Bar -->
          <div class="query-bar" id="queryBar">
            <div class="query-bar-main">
              <div class="query-field query-field-filter">
                <span class="query-label">Filter</span>
                <input
                  type="text"
                  id="queryFilter"
                  class="query-input mono"
                  placeholder='{ field: "value" }'
                  spellcheck="false"
                  autocomplete="off"
                />
              </div>
              <div class="query-bar-actions">
                <button id="queryOptionsToggle" class="btn btn-ghost btn-sm query-options-btn">
                  Options
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </button>
                <div style="position:relative;">
                  <button id="savedQueriesBtn" class="btn btn-ghost btn-sm">
                    Saved
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </button>
                  <div id="savedQueriesDropdown" class="saved-queries-dropdown" style="display:none;"></div>
                </div>
                <button id="queryResetBtn" class="btn btn-ghost btn-sm">Reset</button>
                <button id="queryExplainBtn" class="btn btn-ghost btn-sm" title="Explain query plan">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 16v-4M12 8h.01"/>
                  </svg>
                  Explain
                </button>
                <button id="queryRunBtn" class="btn btn-primary btn-sm">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                  </svg>
                  Find
                </button>
              </div>
            </div>
            <div class="query-bar-options" id="queryBarOptions" style="display:none;">
              <div class="query-field">
                <span class="query-label">Project</span>
                <input
                  type="text"
                  id="queryProjection"
                  class="query-input mono"
                  placeholder='{ field: 1 }'
                  spellcheck="false"
                  autocomplete="off"
                />
              </div>
              <div class="query-field">
                <span class="query-label">Sort</span>
                <input
                  type="text"
                  id="querySort"
                  class="query-input mono"
                  placeholder='{ field: -1 }'
                  spellcheck="false"
                  autocomplete="off"
                />
              </div>
              <div class="query-field query-field-sm">
                <span class="query-label">Limit</span>
                <input type="number" id="queryLimit" class="query-input" value="50" min="1" max="1000" />
              </div>
              <div class="query-field query-field-sm">
                <span class="query-label">Skip</span>
                <input type="number" id="querySkip" class="query-input" value="0" min="0" />
              </div>
              <button id="saveQueryBtn" class="btn btn-ghost btn-sm" title="Save current query">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                  <polyline points="17 21 17 13 7 13 7 21"/>
                  <polyline points="7 3 7 8 15 8"/>
                </svg>
                Save
              </button>
            </div>
          </div>

          <div class="table-container" id="tableViewContainer">
            <table class="data-table" id="dataTable">
              <thead>
                <tr id="tableHeader"></tr>
              </thead>
              <tbody id="tableBody">
                <tr class="loading-row">
                  <td colspan="100">
                    <div class="loading-spinner"></div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="list-view-container" id="listViewContainer" style="display:none">
            <div id="listViewBody"></div>
          </div>

          <div class="json-view-container" id="jsonViewContainer" style="display:none">
            <pre id="jsonViewBody" class="json-view-pre"></pre>
          </div>

          <div class="pagination" id="pagination" style="display: none">
            <button id="loadMoreBtn" class="btn btn-ghost">Load More</button>
            <span id="paginationInfo" class="pagination-info"></span>
          </div>
          </div><!-- end #panel-documents -->

          <!-- Indexes panel -->
          <div id="panel-indexes" style="display:none;flex:1;flex-direction:column;overflow:hidden">
            <div class="content-header">
              <div class="content-title">
                <h2>Indexes</h2>
                <span id="indexCount" class="doc-count"></span>
              </div>
              <div class="content-actions">
                <button id="refreshIndexesBtn" class="btn btn-ghost">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M23 4v6h-6M1 20v-6h6"/>
                    <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                  </svg>
                </button>
                <button id="createIndexBtn" class="btn btn-primary">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 5v14M5 12h14"/>
                  </svg>
                  Create Index
                </button>
              </div>
            </div>
            <div class="table-container">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Keys</th>
                    <th>Properties</th>
                    <th>Size</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="indexTableBody">
                  <tr class="loading-row"><td colspan="5"><div class="loading-spinner"></div></td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Schema Analysis panel -->
          <div id="panel-schema" style="display:none;flex:1;flex-direction:column;overflow:auto">
            <div class="content-header">
              <div class="content-title">
                <h2>Schema Analysis</h2>
                <span id="schemaSampleInfo" class="doc-count"></span>
              </div>
              <div class="content-actions">
                <label style="font-size:12px;color:var(--text-secondary)">Sample size</label>
                <select id="schemaSampleSize" class="query-input" style="width:90px">
                  <option value="100">100</option>
                  <option value="500" selected>500</option>
                  <option value="1000">1,000</option>
                  <option value="5000">5,000</option>
                </select>
                <button id="runSchemaAnalysis" class="btn btn-primary btn-sm">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                  </svg>
                  Analyze
                </button>
              </div>
            </div>
            <div id="schemaContent" style="padding:24px;overflow:auto">
              <div class="empty-state" style="height:auto;padding:60px 0">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                </svg>
                <h3>Run schema analysis</h3>
                <p>Click Analyze to sample documents and visualize the schema</p>
              </div>
            </div>
          </div>

          <!-- Aggregation Pipeline Builder panel -->
          <div id="panel-aggregation" style="display:none;flex:1;flex-direction:row;overflow:hidden;min-height:0">
            <!-- Left: stage list -->
            <div class="agg-stages-col">
              <div class="agg-toolbar">
                <button id="aggAddStage" class="btn btn-primary btn-sm">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 5v14M5 12h14"/>
                  </svg>
                  Add Stage
                </button>
                <button id="aggRun" class="btn btn-ghost btn-sm">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                  </svg>
                  Run
                </button>
                <div style="position:relative">
                  <button id="aggSavedBtn" class="btn btn-ghost btn-sm">Saved ▾</button>
                  <div id="aggSavedDropdown" class="saved-queries-dropdown" style="display:none"></div>
                </div>
                <button id="aggSave" class="btn btn-ghost btn-sm" title="Save pipeline">Save</button>
                <button id="aggExportBtn" class="btn btn-ghost btn-sm">Export ▾</button>
                <div id="aggExportDropdown" class="saved-queries-dropdown" style="display:none;min-width:180px">
                  <div class="saved-query-item" data-lang="js">JavaScript (mongosh)</div>
                  <div class="saved-query-item" data-lang="nodejs">Node.js Driver</div>
                  <div class="saved-query-item" data-lang="python">Python (pymongo)</div>
                  <div class="saved-query-item" data-lang="java">Java Driver</div>
                  <div class="saved-query-item" data-lang="csharp">C# (.NET Driver)</div>
                  <div class="saved-query-item" data-lang="go">Go Driver</div>
                </div>
              </div>
              <div id="aggStageList" class="agg-stage-list">
                <div class="agg-empty-state">
                  <p>No stages yet. Click <strong>Add Stage</strong> to begin.</p>
                </div>
              </div>
            </div>
            <!-- Right: preview -->
            <div class="agg-preview-col">
              <div class="agg-preview-header">
                <span id="aggResultCount" style="font-size:12px;color:var(--text-secondary)">No results</span>
                <label style="font-size:12px;color:var(--text-secondary)">Preview limit</label>
                <select id="aggPreviewLimit" class="query-input" style="width:70px;padding:3px 6px;font-size:12px">
                  <option value="5">5</option>
                  <option value="10">10</option>
                  <option value="20" selected>20</option>
                  <option value="50">50</option>
                </select>
              </div>
              <div id="aggResultBody" class="agg-result-body">
                <div class="agg-result-placeholder">Run the pipeline to see results</div>
              </div>
            </div>
          </div>

          <!-- Validation panel -->
          <div id="panel-validation" style="display:none;flex:1;flex-direction:column;overflow:auto">
            <div class="content-header">
              <div class="content-title"><h2>Schema Validation</h2></div>
              <div class="content-actions">
                <button id="saveValidation" class="btn btn-primary btn-sm">Save Changes</button>
              </div>
            </div>
            <div id="validationContent" style="padding:24px;max-width:860px">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">
                <div class="form-field">
                  <label>Validation Level</label>
                  <select id="validationLevel" class="query-input">
                    <option value="off">off — No validation</option>
                    <option value="moderate">moderate — Validate inserts and updates to existing valid docs</option>
                    <option value="strict">strict — Validate all inserts and updates</option>
                  </select>
                </div>
                <div class="form-field">
                  <label>Validation Action</label>
                  <select id="validationAction" class="query-input">
                    <option value="error">error — Reject invalid documents</option>
                    <option value="warn">warn — Log warning but allow invalid documents</option>
                  </select>
                </div>
              </div>
              <div class="form-field">
                <label>Validator (JSON Schema or MQL expression)</label>
                <textarea id="validatorEditor" class="doc-editor" style="min-height:280px" spellcheck="false" placeholder='{ "$jsonSchema": { "bsonType": "object", "required": ["name"], "properties": { "name": { "bsonType": "string" } } } }'></textarea>
              </div>
              <p id="validationError" class="error-message" style="display:none;margin-top:10px"></p>
              <p id="validationSuccess" style="display:none;margin-top:10px;padding:10px;background:rgba(63,185,80,0.1);border:1px solid var(--success);border-radius:var(--radius);color:var(--success);font-size:13px">Validation rules saved successfully.</p>
              <div style="margin-top:20px">
                <button id="testValidation" class="btn btn-ghost btn-sm">Test against 10 sample docs</button>
                <div id="validationTestResults" style="margin-top:12px;font-size:13px"></div>
              </div>
            </div>
          </div>

          <!-- Stats panel -->
          <div id="panel-stats" style="display:none;flex:1;flex-direction:column;overflow:auto">
            <div class="content-header">
              <div class="content-title"><h2>Collection Statistics</h2></div>
              <div class="content-actions">
                <button id="refreshStats" class="btn btn-ghost btn-sm">Refresh</button>
              </div>
            </div>
            <div id="statsContent" style="padding:24px">
              <div class="loading-spinner"></div>
            </div>
          </div>

          <!-- Change Stream panel -->
          <div id="panel-changes" style="display:none;flex:1;flex-direction:column;overflow:hidden">
            <div class="content-header">
              <div class="content-title"><h2>Change Stream</h2></div>
              <div class="content-actions" style="gap:8px">
                <select id="csOpFilter" class="conn-field" style="width:auto;min-width:140px;height:32px;font-size:12px">
                  <option value="all">All operations</option>
                  <option value="insert">Insert</option>
                  <option value="update">Update</option>
                  <option value="replace">Replace</option>
                  <option value="delete">Delete</option>
                </select>
                <button id="csToggle" class="btn btn-primary btn-sm">Start Watching</button>
                <button id="csClear" class="btn btn-ghost btn-sm">Clear</button>
              </div>
            </div>
            <div id="csEvents" class="cs-events-container">
              <div class="cs-empty-state">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <p>Click <strong>Start Watching</strong> to listen for real-time changes on this collection.</p>
                <p class="cs-hint">Requires a replica set or MongoDB Atlas. Changes from inserts, updates, and deletes will appear here live.</p>
              </div>
            </div>
          </div>

          <!-- SQL to MQL panel -->
          <div id="panel-sql" style="display:none;flex:1;flex-direction:column;overflow:hidden">
            <div class="content-header">
              <div class="content-title"><h2>SQL &rarr; MongoDB Query</h2></div>
              <div class="content-actions" style="gap:8px">
                <button id="sqlConvertBtn" class="btn btn-primary btn-sm">Convert</button>
                <button id="sqlRunBtn" class="btn btn-ghost btn-sm" style="display:none">Run Query</button>
              </div>
            </div>
            <div class="sql-converter">
              <div class="sql-input-section">
                <label class="sql-label">SQL Query</label>
                <textarea id="sqlInput" class="doc-editor" placeholder="SELECT name, age FROM collection WHERE age > 25 ORDER BY name LIMIT 10" spellcheck="false"></textarea>
                <div class="sql-examples">
                  <span class="sql-examples-label">Examples:</span>
                  <button class="btn btn-ghost btn-xs sql-example-btn" data-sql="SELECT * FROM collection WHERE status = 'active' LIMIT 20">SELECT</button>
                  <button class="btn btn-ghost btn-xs sql-example-btn" data-sql="SELECT name, COUNT(*) as total FROM collection GROUP BY name">GROUP BY</button>
                  <button class="btn btn-ghost btn-xs sql-example-btn" data-sql="UPDATE collection SET status = 'archived' WHERE age > 30">UPDATE</button>
                  <button class="btn btn-ghost btn-xs sql-example-btn" data-sql="DELETE FROM collection WHERE status = 'inactive'">DELETE</button>
                </div>
              </div>
              <div class="sql-output-section">
                <label class="sql-label">MongoDB Query</label>
                <textarea id="sqlOutput" class="doc-editor" readonly></textarea>
              </div>
            </div>
          </div>

          <!-- Export Code Modal -->
          <div id="aggExportModal" class="modal" style="display:none">
            <div class="modal-backdrop"></div>
            <div class="modal-content modal-lg">
              <div class="modal-header">
                <h3 id="aggExportTitle">Export Pipeline</h3>
                <button class="modal-close" id="aggExportModalClose">&times;</button>
              </div>
              <div class="modal-body">
                <textarea id="aggExportCode" class="doc-editor" style="min-height:320px" readonly></textarea>
              </div>
              <div class="modal-footer">
                <button id="aggExportCopy" class="btn btn-ghost">Copy</button>
                <button id="aggExportModalClose2" class="btn btn-primary">Close</button>
              </div>
            </div>
          </div>

          <!-- Create Index Modal -->
          <div id="createIndexModal" class="modal" style="display:none">
            <div class="modal-backdrop"></div>
            <div class="modal-content">
              <div class="modal-header">
                <h3>Create Index</h3>
                <button class="modal-close" id="createIndexModalClose">&times;</button>
              </div>
              <div class="modal-body">
                <div class="form-field">
                  <label>Fields (JSON key spec)</label>
                  <input type="text" id="indexKey" class="query-input mono" placeholder='{ field: 1 }' autocomplete="off"/>
                  <span style="font-size:11px;color:var(--text-muted);margin-top:4px;display:block">Use 1 for ascending, -1 for descending, "text", "2dsphere", "hashed"</span>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px">
                  <div class="form-field" style="display:flex;align-items:center;gap:8px">
                    <input type="checkbox" id="indexUnique"/>
                    <label for="indexUnique" style="margin:0">Unique</label>
                  </div>
                  <div class="form-field" style="display:flex;align-items:center;gap:8px">
                    <input type="checkbox" id="indexSparse"/>
                    <label for="indexSparse" style="margin:0">Sparse</label>
                  </div>
                </div>
                <div class="form-field" style="margin-top:12px">
                  <label>TTL — expireAfterSeconds (optional)</label>
                  <input type="number" id="indexTTL" class="query-input" placeholder="e.g. 3600" min="0"/>
                </div>
                <div class="form-field" style="margin-top:12px">
                  <label>Custom name (optional)</label>
                  <input type="text" id="indexName" class="query-input" placeholder="Auto-generated if blank" autocomplete="off"/>
                </div>
                <p id="createIndexError" class="error-message" style="display:none;margin-top:10px"></p>
              </div>
              <div class="modal-footer">
                <button id="createIndexCancel" class="btn btn-ghost">Cancel</button>
                <button id="createIndexConfirm" class="btn btn-primary">Create Index</button>
              </div>
            </div>
          </div>

          <!-- Drop Index Modal -->
          <div id="dropIndexModal" class="modal" style="display:none">
            <div class="modal-backdrop"></div>
            <div class="modal-content modal-sm">
              <div class="modal-header">
                <h3>Drop Index</h3>
                <button class="modal-close" id="dropIndexModalClose">&times;</button>
              </div>
              <div class="modal-body">
                <p>Drop index <strong id="dropIndexName"></strong>?</p>
                <p id="dropIndexError" class="error-message" style="display:none;margin-top:10px"></p>
              </div>
              <div class="modal-footer">
                <button id="dropIndexCancel" class="btn btn-ghost">Cancel</button>
                <button id="dropIndexConfirm" class="btn btn-danger">Drop</button>
              </div>
            </div>
          </div>

          <% } else { %>
          <div class="empty-state">
            <svg
              width="64"
              height="64"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
            >
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
              <path d="M14 2v6h6" />
            </svg>
            <h3>Select a Collection</h3>
            <p>Choose a collection from the sidebar to browse documents</p>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Document Modal -->
      <div id="docModal" class="modal" style="display: none">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
          <div class="modal-header">
            <h3 id="modalTitle">Document</h3>
            <button class="modal-close" id="modalClose">&times;</button>
          </div>
          <div class="modal-body">
            <div id="formToggle" class="form-toggle" style="display: none">
              <button id="useFormBtn" class="btn btn-sm btn-ghost active">
                Form
              </button>
              <button id="useJsonBtn" class="btn btn-sm btn-ghost">JSON</button>
            </div>
            <div id="docFormContainer" style="display: none"></div>
            <textarea
              id="docEditor"
              class="doc-editor"
              spellcheck="false"
            ></textarea>
            <p id="editorError" class="error-message" style="display: none"></p>
          </div>
          <div class="modal-footer">
            <button id="modalCancel" class="btn btn-ghost">Cancel</button>
            <button
              id="modalDelete"
              class="btn btn-danger"
              style="display: none"
            >
              Delete
            </button>
            <button id="modalSave" class="btn btn-primary">Save</button>
          </div>
        </div>
      </div>

      <!-- Delete Confirmation Modal -->
      <div id="deleteModal" class="modal" style="display: none">
        <div class="modal-backdrop"></div>
        <div class="modal-content modal-sm">
          <div class="modal-header">
            <h3>Confirm Delete</h3>
            <button class="modal-close" id="deleteModalClose">&times;</button>
          </div>
          <div class="modal-body">
            <p>
              Are you sure you want to delete this document? This action cannot
              be undone.
            </p>
          </div>
          <div class="modal-footer">
            <button id="deleteCancel" class="btn btn-ghost">Cancel</button>
            <button id="deleteConfirm" class="btn btn-danger">Delete</button>
          </div>
        </div>
      </div>

      <!-- Column Selector Modal -->
      <div id="columnsModal" class="modal" style="display: none">
        <div class="modal-backdrop"></div>
        <div class="modal-content modal-sm">
          <div class="modal-header">
            <h3>Select Columns</h3>
            <button class="modal-close" id="columnsModalClose">&times;</button>
          </div>
          <div class="modal-body">
            <div class="columns-selector">
              <div class="columns-actions">
                <button id="selectAllColumns" class="btn btn-sm btn-ghost">
                  Select All
                </button>
                <button id="deselectAllColumns" class="btn btn-sm btn-ghost">
                  Deselect All
                </button>
              </div>
              <div id="columnsList" class="columns-list"></div>
            </div>
          </div>
          <div class="modal-footer">
            <button id="columnsCancel" class="btn btn-ghost">Cancel</button>
            <button id="columnsApply" class="btn btn-primary">Apply</button>
          </div>
        </div>
      </div>

      <!-- View Document Modal -->
      <div id="viewModal" class="modal" style="display: none">
        <div class="modal-backdrop"></div>
        <div class="modal-content modal-lg">
          <div class="modal-header">
            <h3>View Document</h3>
            <div style="display: flex; gap: 8px; align-items: center;">
              <button id="viewModalCopyBtn" class="btn btn-sm btn-ghost" title="Copy JSON">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
                </svg>
                Copy
              </button>
              <button id="viewModalDuplicateBtn" class="btn btn-sm btn-ghost" title="Duplicate Document">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
                  <line x1="15.5" y1="12.5" x2="15.5" y2="18.5"/><line x1="12.5" y1="15.5" x2="18.5" y2="15.5"/>
                </svg>
                Duplicate
              </button>
              <button class="modal-close" id="viewModalClose">&times;</button>
            </div>
          </div>
          <div class="modal-body">
            <div id="viewDocumentContent" class="json-viewer">
              <div class="loading-spinner"></div>
            </div>
          </div>
          <div class="modal-footer">
            <button id="viewModalPopulateBtn" class="btn btn-primary">Populate</button>
            <button id="viewModalCloseBtn" class="btn btn-ghost">Close</button>
          </div>
        </div>
      </div>
    </main>

      <!-- Explain Plan Modal -->
      <div id="explainModal" class="modal" style="display:none">
        <div class="modal-backdrop"></div>
        <div class="modal-content modal-lg" style="max-height:85vh">
          <div class="modal-header">
            <h3>Explain Plan</h3>
            <div style="display:flex;gap:8px;align-items:center">
              <button id="explainRawToggle" class="btn btn-sm btn-ghost">Raw JSON</button>
              <button class="modal-close" id="explainModalClose">&times;</button>
            </div>
          </div>
          <div class="modal-body" style="overflow:auto">
            <div id="explainSummary" class="explain-summary" style="display:none"></div>
            <div id="explainTree" style="display:none"></div>
            <div id="explainRaw" class="json-viewer" style="display:none"></div>
            <div id="explainLoading" style="display:flex;justify-content:center;padding:40px">
              <div class="loading-spinner"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Import Modal -->
      <div id="importModal" class="modal" style="display:none">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
          <div class="modal-header">
            <h3>Import Documents</h3>
            <button class="modal-close" id="importModalClose">&times;</button>
          </div>
          <div class="modal-body">
            <div class="form-field">
              <label>File (JSON or CSV)</label>
              <input type="file" id="importFile" accept=".json,.csv,.ndjson" style="padding:6px;color:var(--text-primary);background:var(--bg-primary);border:1px solid var(--border);border-radius:var(--radius);width:100%;cursor:pointer"/>
            </div>
            <div class="form-field" style="margin-top:12px">
              <label>Format</label>
              <select id="importFormat" class="query-input">
                <option value="json">JSON (array or NDJSON)</option>
                <option value="csv">CSV</option>
              </select>
            </div>
            <div class="form-field" style="margin-top:12px;display:flex;align-items:center;gap:8px">
              <input type="checkbox" id="importStopOnError" style="width:auto"/>
              <label for="importStopOnError" style="margin:0">Stop on first error</label>
            </div>
            <div id="importPreview" style="margin-top:12px;font-size:12px;color:var(--text-secondary);font-family:monospace;background:var(--bg-primary);border:1px solid var(--border);border-radius:var(--radius);padding:8px;max-height:120px;overflow:auto;display:none"></div>
            <p id="importError" class="error-message" style="display:none;margin-top:10px"></p>
            <p id="importResult" style="display:none;margin-top:10px;padding:10px;background:rgba(63,185,80,0.1);border:1px solid var(--success);border-radius:var(--radius);color:var(--success);font-size:13px"></p>
          </div>
          <div class="modal-footer">
            <button id="importCancel" class="btn btn-ghost">Cancel</button>
            <button id="importConfirm" class="btn btn-primary" disabled>Import</button>
          </div>
        </div>
      </div>

      <!-- Export Modal -->
      <div id="exportModal" class="modal" style="display:none">
        <div class="modal-backdrop"></div>
        <div class="modal-content modal-sm">
          <div class="modal-header">
            <h3>Export Documents</h3>
            <button class="modal-close" id="exportModalClose">&times;</button>
          </div>
          <div class="modal-body">
            <div class="form-field">
              <label>Format</label>
              <select id="exportFormat" class="query-input">
                <option value="json">JSON</option>
                <option value="csv">CSV</option>
                <option value="jsonl">JSONL (Newline Delimited)</option>
              </select>
            </div>
            <div class="form-field" style="margin-top:12px">
              <label>Max documents (up to 100,000)</label>
              <input type="number" id="exportLimit" class="query-input" value="10000" min="1" max="100000"/>
            </div>
            <p style="margin-top:12px;font-size:12px;color:var(--text-muted)">Exports the current query filter and sort.</p>
          </div>
          <div class="modal-footer">
            <button id="exportCancel" class="btn btn-ghost">Cancel</button>
            <button id="exportConfirm" class="btn btn-primary">Download</button>
          </div>
        </div>
      </div>

      <!-- Shell Panel -->
      <div id="shellPanel" class="shell-panel shell-panel-closed">
        <div class="shell-header">
          <div style="display:flex;align-items:center;gap:8px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
            </svg>
            <span style="font-size:12px;font-weight:600;font-family:monospace">mongosh</span>
            <span id="shellDbLabel" style="font-size:11px;color:var(--text-muted);font-family:monospace"></span>
          </div>
          <div style="display:flex;gap:6px">
            <button id="shellClearBtn" class="btn btn-sm btn-ghost" style="padding:3px 8px;font-size:11px">Clear</button>
            <button id="shellToggleBtn" class="shell-toggle-btn" title="Toggle shell">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 15l-6-6-6 6"/>
              </svg>
            </button>
          </div>
        </div>
        <div id="shellOutput" class="shell-output"></div>
        <div class="shell-input-row">
          <span class="shell-prompt">></span>
          <input type="text" id="shellInput" class="shell-input" placeholder="db.collection.find({})" spellcheck="false" autocomplete="off"/>
          <button id="shellRunBtn" class="btn btn-sm btn-ghost" style="padding:4px 10px">Run</button>
        </div>
      </div>

      <!-- Shell toggle button (floating, when panel is closed) -->
      <button id="shellOpenBtn" class="shell-open-btn" title="Open shell">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
        </svg>
        Shell
      </button>

    <div id="toastContainer" class="toast-container"></div>

    <script src="/js/app.js"></script>
    <script>
      // Format collection counts
      document.querySelectorAll(".collection-doc-count").forEach((el) => {
        const count = parseInt(el.dataset.count);
        if (!isNaN(count)) {
          el.textContent = formatCount(count);
        }
      });

      const dbName = "<%= dbName %>";
      const activeCollection = '<%= activeCollection || "" %>';
      if (activeCollection) {
        initBrowser(dbName, activeCollection);
      }
      initCollectionManagement(dbName);
    </script>
  </body>
</html>
