<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Performance | MongoDB Dashboard</title>
  <script>
    (function() {
      try {
        const theme = localStorage.getItem('mongodb_dashboard_theme') || 'system';
        document.documentElement.setAttribute('data-theme', theme);
      } catch(e) {
        document.documentElement.setAttribute('data-theme', 'system');
      }
    })();
  </script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <a href="/" class="logo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
      </svg>
      MongoDB Dashboard
    </a>
    <nav class="nav">
      <a href="/databases" class="nav-link">Databases</a>
      <span class="nav-sep">/</span>
      <span class="nav-current">Performance</span>
    </nav>
    <div class="header-actions">
      <div class="theme-toggle">
        <button class="theme-toggle-btn" title="Theme">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="theme-toggle-text">System</span>
        </button>
        <div class="theme-dropdown">
          <div class="theme-option active" data-theme="system"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg><span>System</span></div>
          <div class="theme-option" data-theme="light"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg><span>Light</span></div>
          <div class="theme-option" data-theme="dark"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg><span>Dark</span></div>
        </div>
      </div>
      <button id="disconnectBtn" class="btn btn-sm btn-ghost" title="Disconnect">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/>
        </svg>
      </button>
    </div>
  </header>

  <main class="main" style="overflow:auto">
    <div class="perf-page">
      <div class="perf-header">
        <div>
          <h1>Server Performance</h1>
          <p class="page-subtitle" id="perfServerInfo">Loading…</p>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <label style="font-size:13px;color:var(--text-secondary)">Refresh</label>
          <select id="perfInterval" class="query-input" style="width:100px">
            <option value="1000">1s</option>
            <option value="2000" selected>2s</option>
            <option value="5000">5s</option>
            <option value="0">Paused</option>
          </select>
          <span id="perfLiveIndicator" class="perf-live">● LIVE</span>
        </div>
      </div>

      <!-- Stat cards -->
      <div class="perf-cards" id="perfCards">
        <div class="perf-card"><div class="perf-card-label">Connections (current)</div><div class="perf-card-value" id="stat-conn-current">—</div></div>
        <div class="perf-card"><div class="perf-card-label">Connections (available)</div><div class="perf-card-value" id="stat-conn-available">—</div></div>
        <div class="perf-card"><div class="perf-card-label">Resident Memory</div><div class="perf-card-value" id="stat-mem-resident">—</div></div>
        <div class="perf-card"><div class="perf-card-label">Virtual Memory</div><div class="perf-card-value" id="stat-mem-virtual">—</div></div>
        <div class="perf-card"><div class="perf-card-label">Network In</div><div class="perf-card-value" id="stat-net-in">—</div></div>
        <div class="perf-card"><div class="perf-card-label">Network Out</div><div class="perf-card-value" id="stat-net-out">—</div></div>
      </div>

      <!-- Ops/sec bars -->
      <div class="perf-section">
        <h2 class="perf-section-title">Operations / sec (delta)</h2>
        <div class="perf-ops-grid" id="perfOpsGrid">
          <div class="perf-op-row"><span class="perf-op-label">insert</span><div class="perf-op-track"><div class="perf-op-bar" id="bar-insert" style="background:#3fb950"></div></div><span class="perf-op-val" id="val-insert">0</span></div>
          <div class="perf-op-row"><span class="perf-op-label">query</span><div class="perf-op-track"><div class="perf-op-bar" id="bar-query" style="background:#58a6ff"></div></div><span class="perf-op-val" id="val-query">0</span></div>
          <div class="perf-op-row"><span class="perf-op-label">update</span><div class="perf-op-track"><div class="perf-op-bar" id="bar-update" style="background:#d29922"></div></div><span class="perf-op-val" id="val-update">0</span></div>
          <div class="perf-op-row"><span class="perf-op-label">delete</span><div class="perf-op-track"><div class="perf-op-bar" id="bar-delete" style="background:#f85149"></div></div><span class="perf-op-val" id="val-delete">0</span></div>
          <div class="perf-op-row"><span class="perf-op-label">getmore</span><div class="perf-op-track"><div class="perf-op-bar" id="bar-getmore" style="background:#bc8cff"></div></div><span class="perf-op-val" id="val-getmore">0</span></div>
          <div class="perf-op-row"><span class="perf-op-label">command</span><div class="perf-op-track"><div class="perf-op-bar" id="bar-command" style="background:#79c0ff"></div></div><span class="perf-op-val" id="val-command">0</span></div>
        </div>
      </div>

      <!-- Active operations -->
      <div class="perf-section">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <h2 class="perf-section-title" style="margin:0">Active Operations</h2>
          <button id="refreshOps" class="btn btn-ghost btn-sm">Refresh</button>
        </div>
        <div class="table-container" style="max-height:300px">
          <table class="data-table">
            <thead>
              <tr>
                <th>Op ID</th><th>Type</th><th>Namespace</th><th>Running (s)</th><th>Client</th><th>Action</th>
              </tr>
            </thead>
            <tbody id="currentOpsBody">
              <tr><td colspan="6" style="text-align:center;padding:24px;color:var(--text-muted)">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/app.js"></script>
  <script>
    initPerformancePage();
  </script>
</body>
</html>
